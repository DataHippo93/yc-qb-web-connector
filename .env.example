# QuickBooks Web Connector - Environment Configuration
# Copy to .env and fill in real values

# ---- Supabase ----
QB_SUPABASE_URL=https://vynzrvgoyqorqxogjrgw.supabase.co
QB_SUPABASE_ANON_KEY=your_anon_key_here
QB_SUPABASE_SERVICE_KEY=your_service_role_key_here
QB_SUPABASE_DB_PASS=your_db_password_here

# ---- QBWC Auth ----
# Must match what's in the .qwc file
QBWC_USERNAME=YCConnector
QBWC_PASSWORD=change_me_to_something_strong

# ---- Server ----
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ---- Sync Behavior ----
# Minutes of lookback buffer on incremental syncs (catches records at boundary)
SYNC_LOOKBACK_MINUTES=5
# Default batch size for qbXML queries
QBXML_MAX_RETURNED=100
# Seconds between QBWC poll cycles (set on the Windows side via .qwc MinimumRunEveryNMinutes)
# This env var is informational only
SYNC_INTERVAL_MINUTES=60
